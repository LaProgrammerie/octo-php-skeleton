{
    "name": "async-platform/skeleton",
    "description": "Skeleton project for the Async PHP Platform — create-project template with OpenSwoole runtime pack.",
    "type": "project",
    "license": "MIT",
    "require": {
        "php": ">=8.3",
        "async-platform/runtime-pack": "^1.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "App\\Tests\\": "tests/"
        }
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
