# =============================================================================
# Async PHP Platform — Environment Variables
# =============================================================================
# Copy this file to .env and adjust values for your environment.
# All variables are validated at startup — invalid values prevent the server from starting.
# Full reference: docs/configuration.md
# =============================================================================

# --- Server ---
APP_HOST=0.0.0.0
APP_PORT=8080
# Number of worker processes. 0 = auto-detect (swoole_cpu_num() in prod, 2 in dev).
APP_WORKERS=0

# --- Security ---
# Max HTTP request body size in bytes (default: 2 MB)
MAX_REQUEST_BODY_SIZE=2097152
# Max simultaneous connections
MAX_CONNECTIONS=1024
# Request handler timeout in seconds (applicative deadline, not slowloris protection)
REQUEST_HANDLER_TIMEOUT=60

# --- Graceful Shutdown ---
# Hard timeout in seconds. Should be < Kubernetes terminationGracePeriodSeconds.
SHUTDOWN_TIMEOUT=30

# --- Reload Policy ---
# Workers are automatically restarted when thresholds are reached.
# Set to 0 to disable a specific policy.
# WARNING: disabling ALL policies in prod risks memory leaks and state drift.
MAX_REQUESTS=10000
MAX_UPTIME=3600
# Max RSS memory in bytes (default: 128 MB). Linux only (/proc/self/statm).
MAX_MEMORY_RSS=134217728
# Min interval between worker restarts (anti crash-loop guard)
WORKER_RESTART_MIN_INTERVAL=5

# --- Blocking Pool ---
# Isolates blocking/CPU-bound operations in separate processes.
BLOCKING_POOL_WORKERS=4
BLOCKING_POOL_QUEUE_SIZE=64
BLOCKING_POOL_TIMEOUT=30

# --- Concurrency ---
# Max concurrent request scopes per worker. 0 = unlimited.
# When > 0, excess requests receive 503 immediately.
MAX_CONCURRENT_SCOPES=0

# --- Event Loop Monitoring ---
# Lag threshold in milliseconds for /readyz health check. 0 = disabled.
# When lag exceeds this value, /readyz returns 503.
EVENT_LOOP_LAG_THRESHOLD_MS=500
